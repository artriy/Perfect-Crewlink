{
  "name": "perfect-crewlink",
  "version": "1.0.3",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "Perfect Crewlink desktop client rewritten with TypeScript, Tauri, and Rust",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/artriy/Perfect-Crewlink.git"
  },
  "author": {
    "name": "artriy",
    "url": "https://github.com/artriy"
  },
  "homepage": "https://github.com/artriy/Perfect-Crewlink",
  "bugs": {
    "url": "https://github.com/artriy/Perfect-Crewlink/issues"
  },
  "packageManager": "npm@10",
  "scripts": {
    "dev": "npm run tauri -- dev",
    "dev:halo": "npm run tauri -- dev -c src-tauri/tauri.halo.conf.json",
    "dev:web": "vite",
    "dev:halo:web": "vite --config vite.halo.config.ts",
    "build": "vite build",
    "build:halo": "vite build --config vite.halo.config.ts",
    "preview": "vite preview",
    "tauri": "node scripts/run-tauri.mjs",
    "dist": "npm run tauri -- build",
    "dist:restore-main-binary": "npm run tauri -- build --no-bundle -c src-tauri/tauri.conf.json",
    "dist:halo": "npm run tauri -- build -c src-tauri/tauri.halo.conf.json && node scripts/postbuild-halo.mjs && npm run dist:restore-main-binary",
    "typecheck": "tsc --noEmit",
    "typecheck:halo": "tsc --noEmit -p tsconfig.halo.json",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.1.1",
    "@mui/material": "^7.1.1",
    "@mui/styles": "^6.4.8",
    "@tauri-apps/api": "^2.4.0",
    "@tauri-apps/plugin-dialog": "^2.2.2",
    "@tauri-apps/plugin-opener": "^2.2.7",
    "ajv": "^8.17.1",
    "color": "^5.0.2",
    "i18next": "^25.0.2",
    "jimp": "^1.6.0",
    "pretty-bytes": "^6.1.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-i18next": "^15.5.1",
    "simple-peer": "https://codeload.github.com/vrnagy/simple-peer/tar.gz/35fcb6b25dd15c1e11ff32d522cf7b8016714bc3",
    "socket.io-client": "^2.4.0",
    "source-code-pro": "^2.38.0",
    "typeface-varela": "^1.1.13",
    "webrtc-adapter": "^9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@tauri-apps/cli": "^2.4.0",
    "@types/color": "^3.0.6",
    "@types/node": "^22.14.1",
    "@types/react": "^17.0.89",
    "@types/react-dom": "^17.0.26",
    "@types/simple-peer": "^9.11.8",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.6"
  }
}
